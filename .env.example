# Copy this to .env and fill in your keys

# ATTOM Data (property details, comps)
# Get at: https://api.developer.attomdata.com/
ATTOM_API_KEY=your_attom_key_here

# RentCast (rent estimates, property AVM, assessed values)
# Get at: https://app.rentcast.io/
RENTCAST_API_KEY=your_rentcast_key_here

# Frontend URL (for CORS — set to your Render frontend URL after deploy)
FRONTEND_URL=https://hometrue.onrender.com
